---
import MainLayout from "../layouts/MainLayout.astro";
---

<MainLayout title="Home">

<section class="hero">

    <video autoplay muted loop playsinline class="hero-video">
        <source src="/videos/home-background.mp4" type="video/mp4" />
    </video>

    <div class="overlay"></div>

    <div class="hero-content">

        <h1>A Stranger There</h1>

        <nav class="hero-menu">
            <a href="/photo">Photo</a>
            <a href="/video">Video</a>
            <a href="/art">Art</a>
            <a href="/words">Words</a>
            <a href="/products">Products</a>
            <a href="/music">Music</a>
            <a href="/memo">Memo</a>
        </nav>

        <div class="typewriter" aria-live="polite">
            <p id="typed-text"></p>
            <span class="cursor">|</span>
        </div>

    </div>

    <!-- White circle -->

</section>

<script is:inline>
  const text = `We are all strangers somewhere. Some places become home. Others remain memories. We are all strangers somewhere. We are all strangers somewhere. Some places become home. Others remain memories. We are all strangers somewhere. We are all strangers somewhere. Some places become home. Others remain memories. We are all strangers somewhere.`;

  const target = document.getElementById("typed-text");
  let i = 0;

  function type() {
    if (!target || i >= text.length) return;

    target.textContent += text.charAt(i);
    i++;
    setTimeout(type, 60);
  }

  type();
</script>

</MainLayout>

<style>
.hero{
    position:relative;
    width:100%;
    height:100vh;
    overflow:hidden;
}

.hero-video{
    position:absolute;
    inset:0;
    width:100%;
    height:100%;
    object-fit:cover;
}

.overlay{
    position:absolute;
    inset:0;
    background:rgba(0,0,0,.25);
}

.hero-content{
    position:relative;
    z-index:2;
    height:100%;
    display:flex;
    flex-direction:column;
    justify-content:center;
    align-items:flex-start;
    padding-left:8%;
    color:white;
}
.hero-menu{
    display:flex;
    flex-direction:column;
    gap:0.6rem;
    margin-top:2rem;
}

.hero-menu a{
    color:white;
    text-decoration:none;
    font-size:1.3rem;
    transition:opacity .2s;
}

.hero-menu a:hover{
    opacity:.7;
}
.hero-content h1{
    color:white;
    font-size:clamp(3rem,8vw,7rem);
    font-weight:300;
}

.typewriter {
  position: absolute;
  top: 25%;
  right: 8%;
  width: min(500px, 40%);
  color: white;
  font-family: "Courier New", monospace;
  font-size: 1.1rem;
  line-height: 1.7;
}

.typewriter p{
    margin:0;
}

.cursor{
    animation:blink .8s infinite;
}

@keyframes blink{
    50%{
        opacity:0;
    }
}

@media (max-width: 768px) {
  .hero-content {
    position: relative;
    height: 100%;
    padding: 0;
  }

  .hero-menu {
    position: absolute;
    top: 5vh;
    right: 8%;
    align-items: flex-end;
    text-align: right;
    margin: 0;
  }

  .hero-content h1 {
    position: absolute;
    top: 36%;
    left: 8%;
    right: 8%;
    margin: 0;
    font-size: 2.4rem;
    text-align: left;
  }

  .typewriter {
    top: 62%;
    left: 8%;
    right: 8%;
    width: auto;
    font-size: 0.9rem;
    line-height: 1.5;
  }
}

</style>