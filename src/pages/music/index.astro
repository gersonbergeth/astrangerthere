---
import MainLayout from "../../layouts/MainLayout.astro";
---

<MainLayout title="Music">
  <main class="music-page">

    <video autoplay muted loop playsinline class="background-video">
      <source src="/videos/music/music-background.mp4" type="video/mp4" />
    </video>

    <div class="overlay"></div>

    <a href="/" class="home-circle" aria-label="Return home"></a>

    <h1>But there is no sound!</h1>

    <a
      class="hotspot tuning-dial"
      href="/music/lyrics"
      aria-label="Open a random lyric"
    ></a>

    <a
      class="hotspot cassette-play"
      href="/music/lyrics"
      aria-label="Open a random lyric"
    ></a>

  </main>
</MainLayout>

<style>
  :global(html),
  :global(body) {
    margin: 0;
    width: 100%;
    height: 100%;
    overflow: hidden;
    background: black;
  }

  .music-page {
    position: relative;
    width: 100%;
    height: 100svh;
    overflow: hidden;
    color: white;
  }

  .background-video {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .overlay {
    position: absolute;
    inset: 0;
    background: rgb(0 0 0 / 25%);
  }

  h1 {
    position: absolute;
    left: 3rem;
    top: 50%;
    z-index: 2;
    margin: 0;
    max-width: 10ch;
    transform: translateY(-50%);
    font-size: clamp(2rem, 4vw, 5rem);
    line-height: 0.95;
    font-weight: 300;
  }

  .home-circle {
    position: fixed;
    top: 2rem;
    right: 2rem;
    z-index: 10;
    width: 20px;
    height: 20px;
    border-radius: 50%;
    background: white;
  }

.hotspot {
    position: absolute;
    z-index: 5;
    display: block;

    border-radius: 50%;
    cursor: pointer;

    /* Temporary */
    background: rgba(255, 0, 0, 0.35);
    outline: 2px solid red;
}

.tuning-dial {
    width: 120px;
    height: 120px;
    right: 44%;
    top: 81%;
}

.cassette-play {
    width: 100px;
    height: 100px;
    right: 25%;
    bottom: 25%;
}

  @media (max-width: 768px) {
    h1 {
      left: 1.5rem;
      top: 42%;
      font-size: 2.4rem;
    }

    .home-circle {
      top: 1.5rem;
      right: 1.5rem;
      width: 18px;
      height: 18px;
    }

    .tuning-dial {
      width: 70px;
      height: 70px;
    }

    .cassette-play {
      width: 60px;
      height: 60px;
    }
  }
</style>