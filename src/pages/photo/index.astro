---
import MainLayout from "../../layouts/MainLayout.astro";

const photos = [
  {
    src: "/images/photo/Photo_001.jpg",
    alt: "Photo 001",
    description: "Description for Photo 001.",
  },
  {
    src: "/images/photo/Photo_002.jpg",
    alt: "Photo 002",
    description: "Description for Photo 002.",
  },
  {
    src: "/images/photo/Photo_003.jpg",
    alt: "Photo 003",
    description: "Description for Photo 003.",
  },
  {
    src: "/images/photo/Photo_004.jpg",
    alt: "Photo 004",
    description: "Description for Photo 004.",
  },
];
---

<MainLayout title="Photo">
  <main class="photo-page">

    <!-- Home circle on collage -->
    <a href="/" class="circle home-circle" aria-label="Return home"></a>

    <section class="collage" aria-label="Photo gallery">
      {
        photos.map((photo, index) => (
          <button
            class="photo-card"
            type="button"
            data-index={index}
            data-src={photo.src}
            data-alt={photo.alt}
            data-description={photo.description}
            aria-label={`Open ${photo.alt}`}
          >
            <img src={photo.src} alt={photo.alt} loading="lazy" />
          </button>
        ))
      }
    </section>

    <!-- Fullscreen photo -->
    <section class="viewer" id="viewer" aria-hidden="true">

      <img id="viewer-image" class="viewer-image" src="" alt="" />

      <div class="viewer-navigation">
        <button
          id="back-to-collage"
          class="circle"
          type="button"
          aria-label="Return to collage"
        ></button>

        <a href="/" class="circle" aria-label="Return home"></a>
      </div>

      <button id="dime-button" class="dime-button" type="button">
        Dime
      </button>

      <div id="description-panel" class="description-panel">
        <p id="viewer-description"></p>
      </div>

    </section>

  </main>
</MainLayout>

<style>

:global(html),
:global(body) {
  margin: 0;
  width: 100%;
  height: 100%;
  overflow: hidden;
}

.photo-page {
  width: 100%;
  height: 100svh;
  overflow: hidden;
  background: var(--background);
}

.collage {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  grid-template-rows: repeat(2, 1fr);
  width: 100%;
  height: 100%;
  box-sizing: border-box;
}

.photo-card {
  min-width: 0;
  min-height: 0;
  padding: 0;
  overflow: hidden;
  border: 0;
  background: #000;
  cursor: pointer;
}

.photo-card img {
  width: 100%;
  height: 100%;
  display: block;
  object-fit: cover;
}

  .circle {
    width: 20px;
    height: 20px;
    display: block;
    flex: 0 0 auto;
    padding: 0;
    border: 0;
    border-radius: 50%;
    background: white;
    cursor: pointer;
  }

  .home-circle {
    position: fixed;
    top: 2rem;
    right: 2rem;
    z-index: 20;
  }

  .viewer {
    position: fixed;
    inset: 0;
    z-index: 100;
    display: none;
    overflow: hidden;
    background: #000;
  }

  .viewer.open {
    display: block;
  }

  .viewer-image {
    width: 100%;
    height: 100%;
    display: block;
    object-fit: contain;
  }

  .viewer-navigation {
    position: absolute;
    top: 2rem;
    right: 2rem;
    z-index: 110;
    display: flex;
    gap: 0.75rem;
  }

  .dime-button {
    position: absolute;
    bottom: 2rem;
    left: 2rem;
    z-index: 120;
    padding: 0;
    border: 0;
    color: white;
    background: transparent;
    font-family: "Courier New", monospace;
    font-size: 1rem;
    cursor: pointer;
  }

  .description-panel {
    position: absolute;
    bottom: 0;
    left: 0;
    z-index: 115;
    width: min(700px, 100%);
    padding: 4.5rem 2rem 2rem;
    color: white;
    background: rgb(0 0 0 / 78%);
    transform: translateX(-100%);
    transition: transform 0.45s ease;
  }

  .description-panel.visible {
    transform: translateX(0);
  }

  .description-panel p {
    margin: 0;
    font-family: "Courier New", monospace;
    line-height: 1.6;
  }

@media (max-width: 768px) {
  .collage {
    grid-template-columns: repeat(auto-fill, minmax(90px, 1fr));
    grid-auto-rows: 90px;
  }
}

  .photo-card,
  .photo-card img {
    min-height: 0;
  }

  .home-circle {
    top: 1.5rem;
    right: 1.5rem;
    width: 18px;
    height: 18px;
  }

  .viewer-navigation {
    top: 1.5rem;
    right: 1.5rem;
  }

  .viewer-navigation .circle {
    width: 18px;
    height: 18px;
  }

  .dime-button {
    bottom: 1.5rem;
    left: 1.5rem;
  }

  .description-panel {
    padding: 4rem 1.5rem 1.5rem;
  }

}
</style>

<script>
  const viewer = document.getElementById("viewer");
  const viewerImage = document.getElementById("viewer-image");
  const viewerDescription = document.getElementById("viewer-description");
  const descriptionPanel = document.getElementById("description-panel");
  const dimeButton = document.getElementById("dime-button");
  const backButton = document.getElementById("back-to-collage");
  const photoCards = document.querySelectorAll(".photo-card");

  photoCards.forEach((card) => {
    card.addEventListener("click", () => {
      if (
        !viewer ||
        !viewerImage ||
        !viewerDescription ||
        !descriptionPanel
      ) {
        return;
      }

      viewerImage.setAttribute("src", card.dataset.src ?? "");
      viewerImage.setAttribute("alt", card.dataset.alt ?? "");
      viewerDescription.textContent = card.dataset.description ?? "";

      descriptionPanel.classList.remove("visible");
      viewer.classList.add("open");
      viewer.setAttribute("aria-hidden", "false");
      document.body.style.overflow = "hidden";
    });
  });

  dimeButton?.addEventListener("click", () => {
    descriptionPanel?.classList.toggle("visible");
  });

  backButton?.addEventListener("click", () => {
    viewer?.classList.remove("open");
    viewer?.setAttribute("aria-hidden", "true");
    descriptionPanel?.classList.remove("visible");
    document.body.style.overflow = "";
  });
</script>